{
  "skill_name": "wiki",
  "evals": [
    {
      "id": 1,
      "eval_name": "init-wiki-in-project",
      "prompt": "初始化一个维基到 /tmp/code-wiki-test，使用项目优先模式（默认 ./wiki）",
      "expected_output": "创建 wiki 目录结构，包含 raw/, wiki/, schema/, index.md, log.md",
      "assertions": [
        {"type": "file_exists", "path": "/tmp/code-wiki-test/wiki/entities"},
        {"type": "file_exists", "path": "/tmp/code-wiki-test/wiki/concepts"},
        {"type": "file_exists", "path": "/tmp/code-wiki-test/index.md"}
      ]
    },
    {
      "id": 2,
      "eval_name": "ingest-split-by-topic",
      "prompt": "将测试文档 /tmp/test-ai.md 摄取到 /tmp/code-wiki-test 维基。文档包含两个主题：大模型和机器人。",
      "expected_output": "生成 10-15 个页面，包括：2个 summary（按主题拆分）、实体页、概念页、关系页等",
      "assertions": [
        {"type": "file_count_in_dir", "dir": "/tmp/code-wiki-test/wiki/summaries", "min": 2, "max": 3},
        {"type": "file_contains", "path": "/tmp/code-wiki-test/log.md", "pattern": "ingest"}
      ]
    },
    {
      "id": 3,
      "eval_name": "query-with-citation",
      "prompt": "在维基 /tmp/code-wiki-test 中查询：什么是大模型？",
      "expected_output": "返回答案，包含 [[entities/]] 或 [[concepts/]] 引用",
      "assertions": [
        {"type": "output_contains", "pattern": "[["}
      ]
    },
    {
      "id": 4,
      "eval_name": "lint-check-health",
      "prompt": "对维基 /tmp/code-wiki-test 运行健康检查",
      "expected_output": "检查结果，包含 orphan pages、missing links 等信息",
      "assertions": [
        {"type": "output_contains", "pattern": "orphan|links|index"}
      ]
    },
    {
      "id": 5,
      "eval_name": "visualize-generates-html",
      "prompt": "可视化维基 /tmp/code-wiki-test 的知识图谱",
      "expected_output": "生成交互式 HTML 文件",
      "assertions": [
        {"type": "output_contains", "pattern": "html|visualize"}
      ]
    },
    {
      "id": 6,
      "eval_name": "insight-create-synthesis",
      "prompt": "手动创建一个关于 AI 发展趋势的洞察页",
      "expected_output": "在 wiki/synthesis/ 目录创建洞察文件",
      "assertions": [
        {"type": "output_contains", "pattern": "synthesis|insight"}
      ]
    },
    {
      "id": 7,
      "eval_name": "schema-view-rules",
      "prompt": "查看维基的行为规范",
      "expected_output": "显示 schema/CLAUDE.md 内容",
      "assertions": [
        {"type": "output_contains", "pattern": "schema|CLAUDE.md"}
      ]
    },
    {
      "id": 8,
      "eval_name": "init-global-location",
      "prompt": "在全局位置 ~/.openwiki 初始化维基",
      "expected_output": "在用户主目录创建 wiki",
      "assertions": [
        {"type": "output_contains", "pattern": "~/.openwiki"}
      ]
    },
    {
      "id": 9,
      "eval_name": "ingest-10-15-pages-target",
      "prompt": "摄取文档后验证触达页面数是否达到 10-15 页",
      "expected_output": "总计页数在 10-15 之间",
      "assertions": [
        {"type": "output_contains", "pattern": "10-15|触达"}
      ]
    },
    {
      "id": 10,
      "eval_name": "chinese-command-support",
      "prompt": "使用中文命令 /wiki 摄取 test.md",
      "expected_output": "中文命令正常工作",
      "assertions": [
        {"type": "output_contains", "pattern": "摄取|初始化|查询"}
      ]
    },
    {
      "id": 11,
      "eval_name": "edge-empty-wiki-query",
      "prompt": "在空的维基中查询不存在的内容",
      "expected_output": "提示维基为空，建议先摄取文档",
      "assertions": [
        {"type": "output_contains", "pattern": "空|摄取|init"}
      ]
    },
    {
      "id": 12,
      "eval_name": "edge-duplicate-ingest",
      "prompt": "重复摄取同一个文档到维基",
      "expected_output": "增量更新而非覆盖，保留现有内容",
      "assertions": [
        {"type": "output_contains", "pattern": "更新|追加"}
      ]
    },
    {
      "id": 13,
      "eval_name": "edge-short-document",
      "prompt": "摄取只有一个段落的短文档",
      "expected_output": "正常处理，生成单个 summary",
      "assertions": [
        {"type": "output_contains", "pattern": "summary|summary"}
      ]
    },
    {
      "id": 14,
      "eval_name": "edge-no-structure-document",
      "prompt": "摄取没有任何标题结构的纯文本",
      "expected_output": "仍能提取内容，创建基础 summary",
      "assertions": [
        {"type": "output_contains", "pattern": "summary|内容"}
      ]
    },
    {
      "id": 15,
      "eval_name": "edge-chinese-only-content",
      "prompt": "摄取纯中文文档",
      "expected_output": "正确处理中文内容",
      "assertions": [
        {"type": "output_contains", "pattern": "中文|概念"}
      ]
    },
    {
      "id": 16,
      "eval_name": "edge-english-only-content",
      "prompt": "摄取纯英文文档",
      "expected_output": "正确处理英文内容",
      "assertions": [
        {"type": "output_contains", "pattern": "concept|entity"}
      ]
    },
    {
      "id": 17,
      "eval_name": "edge-mixed-content",
      "prompt": "摄取中英文混合文档",
      "expected_output": "正确处理混合内容",
      "assertions": [
        {"type": "output_contains", "pattern": "LLM|概念"}
      ]
    },
    {
      "id": 18,
      "eval_name": "edge-comparison-document",
      "prompt": "摄取包含 A vs B 对比内容的文档",
      "expected_output": "自动创建 comparisons/ 对比页",
      "assertions": [
        {"type": "output_contains", "pattern": "comparison|对比|vs"}
      ]
    },
    {
      "id": 19,
      "eval_name": "edge-missing-source-file",
      "prompt": "尝试摄取不存在的文件",
      "expected_output": "给出清晰的错误提示",
      "assertions": [
        {"type": "output_contains", "pattern": "不存在|找不到|error"}
      ]
    },
    {
      "id": 20,
      "eval_name": "edge-wiki-not-initialized",
      "prompt": "在未初始化维基的情况下执行 ingest",
      "expected_output": "提示先运行 /wiki init",
      "assertions": [
        {"type": "output_contains", "pattern": "init|初始化"}
      ]
    },
    {
      "id": 21,
      "eval_name": "edge-entity-relation-detection",
      "prompt": "摄取包含多个相关人物的文档",
      "expected_output": "正确识别并建立人物间关系",
      "assertions": [
        {"type": "output_contains", "pattern": "relations|关系"}
      ]
    },
    {
      "id": 22,
      "eval_name": "edge-code-path-extraction",
      "prompt": "摄取包含代码文件路径的文档",
      "expected_output": "提取并关联 code_paths",
      "assertions": [
        {"type": "output_contains", "pattern": "code_paths|src/"}
      ]
    },
    {
      "id": 23,
      "eval_name": "edge-query-save-back",
      "prompt": "查询后选择将答案存回维基",
      "expected_output": "创建新的 synthesis 页面",
      "assertions": [
        {"type": "output_contains", "pattern": "synthesis|存回"}
      ]
    },
    {
      "id": 24,
      "eval_name": "edge-multi-topic-document",
      "prompt": "摄取包含3个以上独立主题的文档",
      "expected_output": "为每个主题创建独立的 summary",
      "assertions": [
        {"type": "output_contains", "pattern": "summary"}
      ]
    },
    {
      "id": 25,
      "eval_name": "edge-project-priority-location",
      "prompt": "在已有 ./wiki 目录的项目中运行 /wiki init",
      "expected_output": "优先使用现有 ./wiki，不创建新目录",
      "assertions": [
        {"type": "output_contains", "pattern": "./wiki|已有"}
      ]
    }
  ]
}